default_platform(:android)

platform :android do
  lane :deploy do |options|
    flavor = options[:flavor]
    track_name = options[:track]

    # Llama al Gradle del proyecto para compilar el App Bundle
    gradle(
      task: "bundle",
      flavor: flavor,
      build_type: "Release"
    )

    # Sube el App Bundle a la tienda de Google, de momento omitido porque no tengo el .json con la firma de de Google Cloud Service Account
    # upload_to_play_store(
