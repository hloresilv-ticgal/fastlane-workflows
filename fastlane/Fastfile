    #  json_key: ENV["PLAY_STORE_JSON_PATH"],
    #  aab: "app/build/outputs/bundle/#{flavor}Release/app-#{flavor}-release.aab",
    #  skip_upload_metadata: true,
    #  skip_upload_images: true,
    #  skip_upload_screenshots: true
    # )
  end
end